# Copie para .env na raiz do repositório (não commite credenciais reais).
# Antes do primeiro `docker compose up`: bash scripts/verify-compose-env.sh
# Guia Debian/VM: deploy/linux-debian/README.md
#
# Porta publicada no hospedeiro para a API + interface web
NETQUASAR_PUBLISH_PORT=8080

# PostgreSQL (Compose) — obrigatórias para o stack predefinido
POSTGRES_USER=quasar
POSTGRES_PASSWORD=altere_esta_senha_em_producao
POSTGRES_DB=netquasar

# Com Postgres neste compose, pode deixar NETQUASAR_DATABASE_URL vazio (usa host "postgres").
# Supabase no Docker: preferir Session pooler do painel (Connect → Session), ex. host aws-0- ou aws-1-REGIAO.pooler.supabase.com:5432, user postgres.SEU_REF.
# NETQUASAR_DATABASE_URL=postgresql://postgres.SEU_REF:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Diretório onde o servidor grava data/database-credentials.json após “Aplicar” na UI (por omissão: ./data relativo ao cwd)
# NETQUASAR_DATA_DIR=/var/lib/netquasar/data

# Opcional: chave(s) de API (comma-separado) — exige X-API-Key ou JWT de login na UI
# NETQUASAR_API_KEYS=

# Segredo HS256 para sessões após login na interface (recomendado em produção, com ou sem API keys)
# NETQUASAR_SESSION_SECRET=altere_para_um_segredo_longo_aleatorio

# Nível de log: trace,debug,info,warn,error
# NETQUASAR_LOG_LEVEL=info

# Origens CORS separadas por vírgula (se o browser aceder de outro host)
# NETQUASAR_CORS_ORIGINS=

# Redis já está no Compose; o core ainda pode não consumir — reservado para cache/realtime futuro
# NETQUASAR_REDIS_URL=redis://redis:6379/0
