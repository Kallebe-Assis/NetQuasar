hillstoneTrapSeverity OBJECT-TYPE
	SYNTAX INTEGER
	{
		 emerg (0),
		 alert (1),
		 crit  (2),
		 err   (3),
		 warning (4),
		 notice   (5),
		 info	(6),
		 debug (7)
	}
	MAX-ACCESS read-only
	STATUS	current
	DESCRIPTION
		"The root of Hillstone's Trap severity OIDs."
	::= { hillstone 4 }


